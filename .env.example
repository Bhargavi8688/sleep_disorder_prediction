# Sleep Disorder Prediction App - Environment Variables
# Copy this file to .env and fill in the values (for local development only)
# For Render deployment, set these variables in the Render Dashboard

# Email Configuration (OTP sending)
# Get your Gmail App Password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here

# Session Secret (can be any random string)
SESSION_SECRET=sleep-disorder-admin-secret-2025

# Asterisk Configuration (Optional - for cloud calling)
# Leave empty if not using cloud calling feature
ASTERISK_ARI_URL=
ASTERISK_ARI_USERNAME=
ASTERISK_ARI_PASSWORD=
ASTERISK_ARI_APP=sleep-disorder-app
ASTERISK_ENDPOINT_PREFIX=
ASTERISK_CALLER_ID=A1 Hospital
